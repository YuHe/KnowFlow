# =============================================================================
# KnowFlow Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL 16)
# -----------------------------------------------------------------------------
DB_USER=knowflow
DB_PASSWORD=change_me_db_password
DB_NAME=knowflow

# Full DSN is constructed automatically in docker-compose:
# DATABASE_URL=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@db:5432/${DB_NAME}

# -----------------------------------------------------------------------------
# Redis 7
# Leave REDIS_PASSWORD empty to disable Redis auth (not recommended for prod)
# -----------------------------------------------------------------------------
REDIS_PASSWORD=change_me_redis_password

# -----------------------------------------------------------------------------
# JWT / Security
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(64))"
# -----------------------------------------------------------------------------
JWT_SECRET=change_me_super_secret_jwt_key_at_least_64_chars_long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# -----------------------------------------------------------------------------
# Super Admin (created on first startup)
# -----------------------------------------------------------------------------
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_PASSWORD=change_me_admin_password

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
ENVIRONMENT=production

# Max file upload size in bytes (default 100 MB)
MAX_UPLOAD_SIZE=104857600

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:8192,https://knowflow.ihope.cc

# -----------------------------------------------------------------------------
# Frontend (Vite build-time variables)
# These are baked into the static bundle at build time
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=/api

# -----------------------------------------------------------------------------
# Ports (for reference; set in docker-compose)
# Frontend (nginx):  8192
# Backend (uvicorn): 8000 (internal only)
# -----------------------------------------------------------------------------
